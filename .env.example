# This is an example file for configuring email notifications for local testing.
#
# 1. Copy this file to a new file named .env
#    cp .env.example .env
#
# 2. Edit the .env file with your actual credentials.
#    For Gmail, you MUST use an "App Password", not your regular password.
#    See: https://support.google.com/accounts/answer/185833
#

# Gmail SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your Credentials
SMTP_USER=example@gmail.com
SMTP_PASS=your_gmail_app_password_here # IMPORTANT: Use an App Password

# Email Details
MAIL_TO=example@gmail.com
MAIL_FROM=example@gmail.com
